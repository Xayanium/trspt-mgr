FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=true

# Option A: provide a full SQL Server ODBC connection string.
# SQLSERVER_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost;DATABASE=SchoolDB;UID=sa;PWD=your_password;TrustServerCertificate=yes;

# Option B: configure pieces. Used when SQLSERVER_CONNECTION_STRING is empty.
SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
SQLSERVER_SERVER=localhost
SQLSERVER_DATABASE=SchoolDB
SQLSERVER_USERNAME=sa
SQLSERVER_PASSWORD=your_password
SQLSERVER_TRUSTED_CONNECTION=false
SQLSERVER_TRUST_CERTIFICATE=yes
